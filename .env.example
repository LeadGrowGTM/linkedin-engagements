# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Frontend uses these (must be prefixed with VITE_)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Apify (get from https://console.apify.com/account/integrations)
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxx

# API Server auth (comma-separated, generate your own)
API_KEYS=my-secret-api-key

# Optional
PORT=3001
